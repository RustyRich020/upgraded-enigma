# Firebase Functions Environment Variables
# Copy this to .env and fill in your keys
# These are server-side only — never exposed to the browser

ADZUNA_ID=your_adzuna_app_id
ADZUNA_KEY=your_adzuna_app_key
JSEARCH_KEY=your_rapidapi_key
GEMINI_KEY=your_gemini_api_key
GROQ_KEY=your_groq_api_key
ABSTRACT_KEY=your_abstract_api_key
HUNTER_KEY=your_hunter_api_key
EMAILJS_PUBLIC=your_emailjs_public_key
EMAILJS_SERVICE=your_emailjs_service_id
EMAILJS_TEMPLATE=your_emailjs_template_id
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
